# MzansiBuilds environment example
# Copy this file to .env.local for local frontend work and to backend/.env for backend work,
# then fill in the real values from Firebase, Vercel, and Render.

# Frontend (Vite)
VITE_BACKEND_URL=http://127.0.0.1:8000
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Backend (FastAPI)
FIREBASE_PROJECT_ID=
GOOGLE_APPLICATION_CREDENTIALS=
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:3000
# Default rate limit used when no per-route rule is matched.
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_PATH_PREFIXES=/ai/help/stream
RATE_LIMIT_RULES=/ai/help/stream:20:60,/projects:60:60,/feed:120:60

# Deployment secrets are configured in GitHub Actions, not committed here.
# GitHub Actions secrets:
# VERCEL_DEPLOY_HOOK_URL=
# RENDER_DEPLOY_HOOK_URL=
